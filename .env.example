# ─────────────────────────────────────────────
# Variables de entorno para el Bot de Telegram
# Copia este archivo como .env y completa los valores
# ─────────────────────────────────────────────

# TOKEN del Bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# URL de conexión a PostgreSQL en Supabase (Transaction Pooler)
# Formato: postgresql://postgres.PROJECT_ID:PASSWORD@aws-X-us-east-Y.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.nwdrgrejingixieajctk:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres
